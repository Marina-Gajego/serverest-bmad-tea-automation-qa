{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Login success response schema",
  "type": "object",
  "required": [
    "message",
    "authorization"
  ],
  "additionalProperties": false,
  "properties": {
    "message": {
      "type": "string",
      "const": "Login realizado com sucesso"
    },
    "authorization": {
      "type": "string",
      "minLength": 1,
      "pattern": "^Bearer\\s.+"
    }
  }
}