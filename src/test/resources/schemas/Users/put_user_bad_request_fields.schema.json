{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Put user field validation error response schema",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": false,
  "properties": {
    "nome": {
      "type": "string",
      "enum": [
        "nome é obrigatório",
        "nome deve ser uma string",
        "nome não pode ficar em branco"
      ]
    },
    "email": {
      "type": "string",
      "enum": [
        "email é obrigatório",
        "email deve ser um email válido",
        "email não pode ficar em branco"
      ]
    },
    "password": {
      "type": "string",
      "enum": [
        "password é obrigatório",
        "password deve ser uma string",
        "password não pode ficar em branco"
      ]
    },
    "administrador": {
      "type": "string",
      "enum": [
        "administrador é obrigatório",
        "administrador deve ser 'true' ou 'false'"
      ]
    }
  }
}
