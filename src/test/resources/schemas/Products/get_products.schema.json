{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Get products success response schema",
  "type": "object",
  "required": [
    "quantidade",
    "produtos"
  ],
  "additionalProperties": false,
  "properties": {
    "quantidade": {
      "type": "integer",
      "minimum": 0
    },
    "produtos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "nome",
          "preco",
          "descricao",
          "quantidade",
          "_id"
        ],
        "additionalProperties": false,
        "properties": {
          "nome": {
            "type": "string"
          },
          "preco": {
            "type": "integer"
          },
          "descricao": {
            "type": "string"
          },
          "quantidade": {
            "type": "integer"
          },
          "_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
