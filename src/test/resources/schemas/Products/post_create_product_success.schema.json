{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Create Product Success Response (201)",
  "description": "Schema for successful product creation response",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "Success message",
      "const": "Cadastro realizado com sucesso"
    },
    "_id": {
      "type": "string",
      "description": "Product ID generated by server",
      "pattern": "^[a-zA-Z0-9]+$"
    }
  },
  "required": ["message", "_id"],
  "additionalProperties": false
}

